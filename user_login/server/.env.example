# ── Express server ────────────────────────────────────────────
PORT=4000

# ── MySQL database ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_DATABASE=park_guide_database

# ── MQTT broker ───────────────────────────────────────────────
MQTT_ENABLED=true
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_TOPIC=ctip/sensor/plant-zone-01/proximity

# ── Email / SMTP (for OTP delivery) ─────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Digital Park Guide <your_email@gmail.com>

# ── AI evidence directory (leave blank to use default) ────────
# AI_EVIDENCE_DIR=

{
  "name": "sfc-review-launcher",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "npm --prefix user_page install && npm --prefix admin_page install && npm --prefix mobile_app install && npm --prefix user_login/server install",
    "dev": "node scripts/dev-all.mjs",
    "dev:hub": "node scripts/hub-server.mjs",
    "dev:user": "npm --prefix user_page run dev",
    "dev:admin": "npm --prefix admin_page run dev",
    "dev:mobile": "npm --prefix mobile_app run web -- --port 8081",
    "dev:server": "npm --prefix user_login/server start",
    "build:user": "npm --prefix user_page run build",
    "build:admin": "npm --prefix admin_page run build",
    "check:mobile": "npm --prefix mobile_app exec expo config -- --type public"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^6.0.3"
  }
}
